# Netlify (and similar) static headers — improves repeat-visit speed
/styles.css
  Cache-Control: public, max-age=0, must-revalidate

/script.js
  Cache-Control: public, max-age=0, must-revalidate

/favicon.svg
  Cache-Control: public, max-age=604800

/images/*
  Cache-Control: public, max-age=604800

/images/payment/*
  Cache-Control: public, max-age=604800

/
  Cache-Control: public, max-age=0, must-revalidate
